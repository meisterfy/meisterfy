{
	"name": "meisterfy",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"test:e2e": "playwright test",
		"test": "npm run test:unit -- --run",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"paraglide:watch": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --watch",
		"paraglide:build": "bunx @inlang/paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"i18n:audit": "bun run scripts/i18n-audit.ts",
		"i18n:audit:check": "bun run scripts/i18n-audit.ts --check"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.14.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/marked": "^6.0.0",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.6",
		"@vitest/coverage-v8": "^4.1.6",
		"bits-ui": "^2.17.3",
		"bun-types": "^1.3.13",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"mode-watcher": "^1.1.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.6",
		"vitest-browser-svelte": "^2.1.0"
	},
	"dependencies": {
		"@icons-pack/svelte-simple-icons": "^7.2.0",
		"@inlang/paraglide-js": "^2.18.0",
		"@sentry/svelte": "^10.51.0",
		"@tanstack/table-core": "^8.21.3",
		"@types/pg": "^8.20.0",
		"chart.js": "^4.5.1",
		"clsx": "^2.1.1",
		"lucide-svelte": "^1.0.1",
		"marked": "^18.0.0",
		"pg": "^8.20.0",
		"tailwind-merge": "^3.5.0"
	}
}