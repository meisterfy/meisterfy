# Server
PORT=8080
APP_ENV=development  # set to 'production' for secure cookies

# Database
DATABASE_URL=postgres://user:password@localhost:5432/meisterfy?sslmode=disable

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=

# Integration credential encryption — AES key, MUST be exactly 16, 24 or 32 bytes.
# Required in production; if empty (dev only) integration secrets are stored in
# plaintext. Generate a 32-byte key with: openssl rand -base64 24 | head -c 32
CREDENTIAL_ENCRYPTION_KEY=

# CORS — allowed origins for the admin panel (comma-separated)
ADMIN_CORS_ORIGINS=http://localhost:5173

# Cookie — leave empty for localhost; in production: .yourdomain.com
COOKIE_DOMAIN=

# Proxy — set to 'true' ONLY when behind a reverse proxy that sets a
# trustworthy X-Forwarded-For / X-Real-IP. When false (default), the rate
# limiter keys on the real TCP peer so the headers cannot be spoofed.
TRUST_PROXY_HEADERS=false

# Sentry (optional)
SENTRY_DSN=

# Playwright E2E base URL (optional)
PLAYWRIGHT_BASE_URL=http://localhost:5173
